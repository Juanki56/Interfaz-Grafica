# URL del backend API
VITE_API_URL=http://localhost:3000

# Auth: activar flujo de verificación de email (registro pendiente + código)
# - false: usa el /register clásico (compatibilidad)
# - true: usa /register-pending + pantalla de verificación
VITE_AUTH_USE_EMAIL_VERIFICATION=false

# Dev-only: forzar que un correo siempre sea admin en el frontend.
# Si no se define, por defecto se usa admin@occitours.com
VITE_FORCED_ADMIN_EMAIL=admin@occitours.com

# Otras configuraciones pueden agregarse aquí
